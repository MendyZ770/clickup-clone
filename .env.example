DATABASE_URL="postgresql://user:password@host:5432/clickup_clone?sslmode=require"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Android Release Signing (définies dans ~/.gradle/gradle.properties ou env CI)
RELEASE_STORE_FILE=
RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=
RELEASE_KEY_PASSWORD=

# Upstash Redis (rate limiting) — optionnel, désactivé si absent
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
